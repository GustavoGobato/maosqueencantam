<script>
// ===================== STORAGE =====================
const STORE_KEY = 'mqe_v5';

function defaultData() {
  return {
    products: [
      { id: 'p1', name: 'Pão de Mel', emoji: '🍯', price: 5.00, desc: 'Pão de mel artesanal com chocolate belga' },
      { id: 'p2', name: 'Bolo', emoji: '🎂', price: 7.00, desc: 'Bolo caseiro feito com amor e carinho' },
      { id: 'p3', name: 'Brigadeiro', emoji: '🍫', price: 2.50, desc: 'Brigadeiro cremoso e irresistível' }
    ],
    orders: [],
    discounts: [],
    clients: [],
    sellers: [],
    blocked: [],
    cfg: {
      pix: '36.120.504/0001-92',
      pixName: 'Helena Aparecida Gobato',
      goal: 500,
      storeOpen: true,
      priceHistory: []
    },
    nextOrderNum: 1
  };
}

function loadData() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if (!raw) return defaultData();
    const d = JSON.parse(raw);
    // Ensure all fields exist (migration safety)
    const def = defaultData();
    if (!d.cfg) d.cfg = def.cfg;
    if (!d.cfg.priceHistory) d.cfg.priceHistory = [];
    if (!d.sellers) d.sellers = [];
    if (!d.blocked) d.blocked = [];
    if (!d.nextOrderNum) d.nextOrderNum = (d.orders?.length || 0) + 1;
    return d;
  } catch (e) {
    console.error('Load error:', e);
    return defaultData();
  }
}

function save() {
  try {
    localStorage.setItem(STORE_KEY, JSON.stringify(D));
  } catch (e) {
    console.error('Save error:', e);
    toast('Erro ao salvar dados. Verifique o armazenamento.', 'err');
  }
}

let D = loadData();

// ===================== RUNTIME STATE =====================
let SESSION = null;
// Cart stores: { [productId]: quantity }
// CartMeta stores: { [productId]: { name, emoji, price } }
let CART = {};
let CART_META = {};
let SELECTED_PAY = null;
let APPLIED_DISC = null;
let COMP_FILE = null;
let ORD_FILTER = 'all';

const ADM_USER = 'gustavo';
const ADM_PASS = 'G#g10122009@B';
const RATE_LABELS = ['', 'Muito ruim 😞', 'Ruim 😕', 'Regular 😐', 'Bom 😊', 'Excelente! 🤩'];

// ===================== UTILS =====================
function uid() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
}

function fmt(v) {
  return 'R$ ' + Number(v || 0).toFixed(2).replace('.', ',');
}

function fmtDate(d) {
  if (!d) return '-';
  try {
    // Handle both ISO strings and date-only strings
    const dt = d.includes('T') ? new Date(d) : new Date(d + 'T12:00:00');
    return dt.toLocaleDateString('pt-BR');
  } catch (e) {
    return d;
  }
}

function statusBadge(s) {
  const labels = { pending: 'Pendente', confirmed: 'Confirmado', ready: 'Pronto', done: 'Entregue', cancelled: 'Cancelado' };
  const cls = { pending: 'b-pend', confirmed: 'b-conf', ready: 'b-ready', done: 'b-done', cancelled: 'b-canc' };
  return `<span class="bdg ${cls[s] || ''}">${labels[s] || s}</span>`;
}

function payBadge(p) {
  const labels = { pix: 'Pix', dinheiro: 'Dinheiro', fiado: 'Fiado' };
  const cls = { pix: 'b-pix', dinheiro: 'b-cash', fiado: 'b-fiado' };
  return `<span class="bdg ${cls[p] || ''}">${labels[p] || p}</span>`;
}

function paidBadge(ps) {
  return ps === 'paid'
    ? '<span class="bdg b-paid">✓ Pago</span>'
    : '<span class="bdg b-unpaid">Pendente</span>';
}

function isOverdue(order) {
  if (!order.fiadoDate) return false;
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  return new Date(order.fiadoDate + 'T00:00:00') < today;
}

function daysUntil(dateStr) {
  if (!dateStr) return null;
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const target = new Date(dateStr + 'T00:00:00');
  return Math.ceil((target - today) / 86400000);
}

function daysLabel(order) {
  const d = daysUntil(order.fiadoDate);
  if (d === null) return '-';
  if (d < 0) return `⚠️ Vencido há ${Math.abs(d)} dia(s)`;
  if (d === 0) return '⚠️ Vence hoje!';
  return `Vence em ${d} dia(s)`;
}

// ===================== TOAST =====================
function toast(msg, type = '') {
  const c = document.getElementById('toasts');
  const el = document.createElement('div');
  el.className = 'toast ' + type;
  el.textContent = msg;
  c.appendChild(el);
  setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; }, 2600);
  setTimeout(() => el.remove(), 3000);
}

// ===================== MODALS =====================
function openOv(id) { document.getElementById(id).classList.add('on'); }
function closeOv(id) { document.getElementById(id).classList.remove('on'); }

document.addEventListener('click', function(e) {
  if (e.target.classList.contains('ov')) e.target.classList.remove('on');
});

// ===================== PAGE NAVIGATION =====================
// All pages are hidden by default via CSS .page{display:none}
// Active page gets .active class
const ALL_PAGES = ['pg-land', 'adm-login', 'cli-login', 'cli-reg', 'pg-admin', 'pg-client'];

function showPage(pageId) {
  ALL_PAGES.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  const target = document.getElementById(pageId);
  if (target) {
    target.classList.add('active');
    window.scrollTo(0, 0);
  }
  if (pageId === 'pg-land') updateStoreBanner();
}

function togglePw(id, btn) {
  const el = document.getElementById(id);
  el.type = el.type === 'password' ? 'text' : 'password';
  btn.textContent = el.type === 'password' ? '👁' : '🙈';
}

function updateStoreBanner() {
  const open = D.cfg.storeOpen !== false;
  const el = document.getElementById('closed-strip');
  if (el) el.style.display = open ? 'none' : 'block';
}

function checkOpen() {
  if (!D.cfg.storeOpen) {
    toast('Loja fechada no momento. Tente mais tarde!', 'warn');
    return;
  }
  showPage('cli-login');
}

// ===================== ADMIN AUTH =====================
function doAdmLogin() {
  const u = document.getElementById('al-u').value.trim().toLowerCase();
  const p = document.getElementById('al-p').value;
  const errEl = document.getElementById('al-err');
  errEl.style.display = 'none';

  // Master admin
  if (u === ADM_USER && p === ADM_PASS) {
    SESSION = { type: 'admin', name: 'Gustavo', role: 'Responsável Comercial', perms: ['all'] };
    launchAdmin();
    return;
  }
  // Other sellers
  const seller = D.sellers.find(s => s.username === u && s.password === p && s.active !== false);
  if (seller) {
    SESSION = { type: 'seller', id: seller.id, name: seller.name, role: 'Vendedor', perms: seller.permissions || [] };
    launchAdmin();
    return;
  }
  errEl.style.display = 'block';
}

function launchAdmin() {
  showPage('pg-admin');
  document.getElementById('sb-un').textContent = SESSION.name;
  document.getElementById('sb-ur').textContent = SESSION.role;
  document.getElementById('sb-av').textContent = SESSION.name[0].toUpperCase();

  const isAdmin = SESSION.type === 'admin';
  document.getElementById('nav-sell').style.display = isAdmin ? 'flex' : 'none';
  document.getElementById('nav-cfg').style.display = isAdmin ? 'flex' : 'none';
  document.getElementById('adm-hr').innerHTML = isAdmin
    ? `<button class="btn btn-out btn-sm" onclick="loadCfgModal();openOv('ov-cfg')">⚙️ Config</button>`
    : '';

  if (!isAdmin) {
    const allowed = ['dashboard', 'orders', 'fiado'];
    document.querySelectorAll('.ni').forEach(n => {
      const fn = n.getAttribute('onclick') || '';
      const match = fn.match(/'(\w+)'/);
      if (match && !allowed.includes(match[1])) n.style.display = 'none';
    });
  }

  renderDash();
  updateBadges();
}

function doAdmOut() {
  SESSION = null;
  showPage('pg-land');
}

// ===================== CLIENT AUTH =====================
function doCliLogin() {
  const u = document.getElementById('cl-u').value.trim().toLowerCase();
  const p = document.getElementById('cl-p').value;
  const errEl = document.getElementById('cl-err');
  errEl.style.display = 'none';
  if (!u || !p) { errEl.textContent = 'Preencha usuário e senha.'; errEl.style.display = 'block'; return; }

  const client = D.clients.find(c => c.username === u && c.password === p && c.active !== false);
  if (!client) { errEl.style.display = 'block'; return; }

  SESSION = { type: 'client', id: client.id, name: client.name };
  launchClient();
}

function doCliReg() {
  const name = document.getElementById('cr-n').value.trim();
  const phone = document.getElementById('cr-ph').value.trim();
  const user = document.getElementById('cr-u').value.trim().toLowerCase().replace(/\s+/g, '');
  const pass = document.getElementById('cr-p').value;
  const errEl = document.getElementById('cr-err');
  errEl.style.display = 'none';

  if (!name || !phone || !user || !pass) {
    errEl.textContent = 'Preencha todos os campos.'; errEl.style.display = 'block'; return;
  }
  if (pass.length < 6) {
    errEl.textContent = 'Senha deve ter no mínimo 6 caracteres.'; errEl.style.display = 'block'; return;
  }
  if (!/^[a-z0-9_]+$/.test(user)) {
    errEl.textContent = 'Usuário: apenas letras minúsculas, números e _.'; errEl.style.display = 'block'; return;
  }
  if (D.clients.find(c => c.username === user) || D.sellers.find(s => s.username === user)) {
    errEl.textContent = 'Este nome de usuário já está em uso.'; errEl.style.display = 'block'; return;
  }

  const client = { id: uid(), name, username: user, password: pass, phone, fiadoLimit: 50, notes: '', active: true, since: new Date().toISOString() };
  D.clients.push(client);
  save();

  SESSION = { type: 'client', id: client.id, name: client.name };
  toast('Conta criada! Bem-vindo(a), ' + name + '! 🎉', 'ok');
  launchClient();
}

function doCliOut() {
  SESSION = null;
  resetCart();
  showPage('pg-land');
}

function launchClient() {
  showPage('pg-client');
  document.getElementById('cli-hi').textContent = SESSION.name.split(' ')[0];
  showClientSection('catalog');
  renderCatalog();
  renderFiadoBanner();
  setupPickupDate();
  renderFavorites();
}

