.cat-price{font-size:14px;font-weight:700;color:var(--copper);font-family:'Playfair Display',serif}
.cat-qty{display:flex;align-items:center;justify-content:center;gap:10px;margin-top:10px}
.qb{width:28px;height:28px;border-radius:50%;border:1.5px solid var(--bege-d);background:var(--cream);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--t2);transition:all .18s;flex-shrink:0;line-height:1}
