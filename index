function openFiadoPay(id) {
  const o = D.orders.find(x => x.id === id);
  if (!o) return;
  const c = D.clients.find(x => x.id === o.clientId);
  document.getElementById('fp-b').innerHTML = `
    <div class="info-box">Registrar pagamento de <strong>${fmt(o.total)}</strong> de <strong>${c ? c.name : ''}</strong> (Pedido #${o.num})</div>
    <div class="warn-box">⚠️ Confirme somente após receber o valor.</div>`;
