  html += '<div class="sc-card"><div class="st m4">⭐ Avaliações</div>';
  if (!ratings.length) html += '<div class="empty"><span class="empty-ico">⭐</span><div class="empty-txt">Nenhuma avaliação ainda.</div></div>';
