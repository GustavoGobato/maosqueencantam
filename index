// THE KEY FIX: changeQty uses only string IDs consistently
function changeQty(productId, delta) {
  const p = D.products.find(x => x.id === productId);
  if (!p) { console.error('Product not found:', productId); return; }

  const current = CART[productId] || 0;
  const newQty = Math.max(0, current + delta);

  if (newQty === 0) {
    delete CART[productId];
    delete CART_META[productId];
  } else {
    CART[productId] = newQty;
    CART_META[productId] = { name: p.name, emoji: p.emoji, price: p.price };
  }

  // Update display
  const qvEl = document.getElementById('qv-' + productId);
  if (qvEl) qvEl.textContent = newQty;

  const ciEl = document.getElementById('ci-' + productId);
  if (ciEl) ciEl.classList.toggle('sel', newQty > 0);

  updateCartUI();
}

function getCartItems() {
  return Object.keys(CART).map(pid => ({
    id: pid,
    qty: CART[pid],
    name: CART_META[pid]?.name || '?',
    emoji: CART_META[pid]?.emoji || '',
    price: CART_META[pid]?.price || 0
  }));
}

function calcCartSubtotal() {
  return getCartItems().reduce((a, i) => a + i.price * i.qty, 0);
}

function calcDiscount(subtotal) {
  if (!APPLIED_DISC) return 0;
  const d = APPLIED_DISC;
  return d.type === 'percent' ? subtotal * d.value / 100 : Math.min(d.value, subtotal);
}

function updateCartUI() {
  const items = getCartItems();
  const hasItems = items.length > 0;
  document.getElementById('cart-area').style.display = hasItems ? 'block' : 'none';
  if (!hasItems) return;

  const subtotal = calcCartSubtotal();
  const discAmt = calcDiscount(subtotal);
  const total = Math.max(0, subtotal - discAmt);

  // Cart items list
  document.getElementById('cart-items-list').innerHTML = items.map(i =>
    `<div class="cart-item-row">
      <span class="cir-name">${i.qty}× ${i.emoji} ${i.name}</span>
      <span class="cir-price">${fmt(i.price * i.qty)}</span>
    </div>`
  ).join('');

  // Discount row
  if (APPLIED_DISC && discAmt > 0) {
    document.getElementById('disc-row').style.display = 'block';
    document.getElementById('disc-disp').textContent = '-' + fmt(discAmt);
  } else {
    document.getElementById('disc-row').style.display = 'none';
  }

  document.getElementById('cart-tot').textContent = fmt(total);

  // Fiado limit info
  if (SELECTED_PAY === 'fiado') updateFiadoLimitInfo(total);
}

function updateFiadoLimitInfo(newTotal) {
  const c = D.clients.find(x => x.id === SESSION.id);
  if (!c) return;
  const currentFiado = D.orders
    .filter(o => o.clientId === c.id && o.payment === 'fiado' && o.paymentStatus === 'unpaid')
    .reduce((a, b) => a + b.total, 0);
  const limit = c.fiadoLimit || 50;
  const available = limit - currentFiado;
  const el = document.getElementById('fiado-lim-info');
  if (!el) return;
  if (newTotal > available) {
    el.innerHTML = `<div class="warn-box">⚠️ Limite de fiado: ${fmt(limit)}. Em aberto: ${fmt(currentFiado)}. Disponível: <strong>${fmt(Math.max(0, available))}</strong>. Este pedido excede o limite.</div>`;
  } else {
    el.innerHTML = `<div class="ok-box">✅ Crédito disponível: ${fmt(Math.max(0, available))} de ${fmt(limit)}</div>`;
  }
}

function selPay(type) {
  SELECTED_PAY = type;
  document.querySelectorAll('.po').forEach(e => e.classList.remove('on'));
  const poEl = document.getElementById('po-' + type);
  if (poEl) poEl.classList.add('on');

  ['pix', 'dinheiro', 'fiado'].forEach(t => {
    const el = document.getElementById('pay-' + t + '-area');
    if (el) el.style.display = t === type ? 'block' : 'none';
  });

  if (type === 'fiado') {
    const sub = calcCartSubtotal();
    const disc = calcDiscount(sub);
    updateFiadoLimitInfo(Math.max(0, sub - disc));
  }
}

function copyPix() {
  navigator.clipboard.writeText(D.cfg.pix || '').then(() => toast('Chave Pix copiada!', 'ok'));
}

function handleComp(input) {
  COMP_FILE = input.files[0]?.name || null;
  document.getElementById('comp-lbl').textContent = COMP_FILE ? '✅ ' + COMP_FILE : 'Toque para anexar comprovante';
  if (COMP_FILE) toast('Comprovante anexado!', 'ok');
}

function applyDisc() {
  const code = document.getElementById('disc-inp').value.trim().toUpperCase();
  if (!code) return;
  const d = D.discounts.find(x => x.code === code);
  if (!d) { toast('Código inválido ou expirado.', 'err'); return; }
  if (d.maxUse > 0 && d.used >= d.maxUse) { toast('Cupom esgotado.', 'err'); return; }
  APPLIED_DISC = d;
  updateCartUI();
  toast('Desconto aplicado! 🎉', 'ok');
}

function submitOrder() {
  const items = getCartItems();

  if (!items.length) { toast('Adicione pelo menos 1 produto ao carrinho.', 'err'); return; }
  if (!SELECTED_PAY) { toast('Selecione a forma de pagamento.', 'err'); return; }

  const pickupDate = document.getElementById('pickup-date').value;
  if (!pickupDate) { toast('Selecione a data de retirada.', 'err'); return; }
  if (D.blocked.some(b => b.date === pickupDate)) { toast('Esta data está bloqueada. Escolha outra.', 'err'); return; }

  if (SELECTED_PAY === 'pix' && !COMP_FILE) { toast('Anexe o comprovante do Pix.', 'err'); return; }

  const fiadoDate = document.getElementById('fiado-date').value;
  if (SELECTED_PAY === 'fiado' && !fiadoDate) { toast('Informe a data de pagamento do fiado.', 'err'); return; }

  // Fiado limit check
  if (SELECTED_PAY === 'fiado') {
    const c = D.clients.find(x => x.id === SESSION.id);
    const limit = c?.fiadoLimit || 50;
    const currentFiado = D.orders
      .filter(o => o.clientId === SESSION.id && o.payment === 'fiado' && o.paymentStatus === 'unpaid')
      .reduce((a, b) => a + b.total, 0);
    const sub = calcCartSubtotal();
    const disc = calcDiscount(sub);
    const newTotal = Math.max(0, sub - disc);
    if (newTotal > limit - currentFiado) { toast('Pedido excede seu limite de fiado disponível.', 'err'); return; }
  }

  const subtotal = calcCartSubtotal();
  let discountInfo = null;
  if (APPLIED_DISC) {
    const amt = calcDiscount(subtotal);
    discountInfo = { code: APPLIED_DISC.code, amount: amt };
    APPLIED_DISC.used++;
  }
  const total = Math.max(0, subtotal - (discountInfo?.amount || 0));

  const order = {
    id: uid(),
    num: D.nextOrderNum++,
    clientId: SESSION.id,
    items: items.map(i => ({ id: i.id, name: i.name, emoji: i.emoji, price: i.price, qty: i.qty })),
    total,
    payment: SELECTED_PAY,
    paymentStatus: 'unpaid',
    status: 'pending',
    date: new Date().toISOString(),
    pickupDate,
    fiadoDate: SELECTED_PAY === 'fiado' ? fiadoDate : null,
    obs: document.getElementById('ord-obs').value.trim(),
    discount: discountInfo,
    comprovante: COMP_FILE,
    rating: null
  };

  D.orders.push(order);
  save();

  toast('🎉 Pedido #' + order.num + ' realizado com sucesso!', 'ok');

  // Reset and go to orders
  renderCatalog(); // resets cart
  renderFiadoBanner();
  setupPickupDate();
  showClientSection('my-orders');
}

function renderMyOrders() {
  const c = D.clients.find(x => x.id === SESSION.id);
  if (!c) return;
  const orders = [...D.orders.filter(o => o.clientId === c.id)].sort((a, b) => new Date(b.date) - new Date(a.date));
  const el = document.getElementById('my-orders-list');
  if (!orders.length) {
    el.innerHTML = '<div class="empty"><span class="empty-ico">📦</span><div class="empty-txt">Nenhum pedido ainda.<br>Que tal escolher uns doces? 🍬</div></div>';
    return;
  }
  el.innerHTML = orders.map(o => {
    const items = (o.items || []).map(i => `${i.qty}× ${i.name}`).join(', ');
    const cashNote = o.payment === 'dinheiro' && o.paymentStatus === 'unpaid'
      ? `<div class="warn-box" style="margin-top:10px">💵 Pagamento em dinheiro na retirada. Aguarde confirmação.</div>` : '';
    const rateBtn = o.status === 'done' && !o.rating
      ? `<button class="btn btn-out btn-sm" style="margin-top:11px" onclick="openRateModal('${o.id}')">⭐ Avaliar pedido</button>`
      : o.rating ? `<div style="margin-top:9px;font-size:17px">${'⭐'.repeat(o.rating)}</div>` : '';
    return `<div class="ord-card">
      <div class="flex jb ic m3">
        <div><div class="fw7 tc" style="font-family:'Playfair Display',serif;font-size:15px">Pedido #${o.num}</div><div class="ts tl">${fmtDate(o.date)}</div></div>
        ${statusBadge(o.status)}
      </div>
      <div class="tm m3">${items}</div>
      <div class="flex jb ic">${payBadge(o.payment)} ${paidBadge(o.paymentStatus)}<div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--copper)">${fmt(o.total)}</div></div>
      ${o.pickupDate ? `<div class="ts tl mt2">📅 Retirada: ${fmtDate(o.pickupDate)}</div>` : ''}
      ${cashNote}${rateBtn}
    </div>`;
  }).join('');
}

function renderExtrato() {
  const c = D.clients.find(x => x.id === SESSION.id);
  if (!c) return;
  const fi = D.orders.filter(o => o.clientId === c.id && o.payment === 'fiado' && o.paymentStatus === 'unpaid');
  const allPaid = D.orders.filter(o => o.clientId === c.id && o.paymentStatus === 'paid');
  const spent = allPaid.reduce((a, b) => a + b.total, 0);
  const fiadoTotal = fi.reduce((a, b) => a + b.total, 0);
  const limit = c.fiadoLimit || 50;
  const available = Math.max(0, limit - fiadoTotal);

  let html = `<div class="ext-hero">
    <div class="ext-hero-lbl">Total gasto (pedidos pagos)</div>
    <div class="ext-hero-v">${fmt(spent)}</div>
    <div class="ext-hero-sub">${allPaid.length} pedido(s) concluído(s)</div>
  </div>
  <div class="ext-grid">
    <div class="sc-card" style="text-align:center"><div class="ts tl m1">Fiado em aberto</div><div style="font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:${fiadoTotal > 0 ? 'var(--err)' : 'var(--sage)'}">${fmt(fiadoTotal)}</div></div>
    <div class="sc-card" style="text-align:center"><div class="ts tl m1">Crédito disponível</div><div style="font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:${available > 0 ? 'var(--sage)' : 'var(--err)'}">${fmt(available)}</div></div>
  </div>`;

  if (fi.length) {
    html += `<div style="font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--ink);margin-bottom:12px">Pendências em aberto</div>`;
    html += fi.map(o => {
      const od = isOverdue(o);
      const items = (o.items || []).map(i => `${i.qty}× ${i.name}`).join(', ');
      return `<div class="ord-card" style="border-left:3px solid ${od ? 'var(--err)' : 'var(--amber)'}">
        <div class="flex jb ic m3">
          <div><div class="fw7 tc">Pedido #${o.num}</div><div class="ts tl">${fmtDate(o.date)}</div></div>
          <span class="bdg ${od ? 'b-over' : 'b-fiado'}">${od ? '⚠️ Vencido' : '📒 Fiado'}</span>
        </div>
        <div class="tm m3">${items}</div>
        <div class="flex jb ic"><span class="ts tl">Venc: ${o.fiadoDate ? fmtDate(o.fiadoDate) : 'N/D'}</span><div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--err)">${fmt(o.total)}</div></div>
        <button class="btn btn-gold btn-full mt3" style="border-radius:var(--r8)" onclick="openClientPix('${o.id}',${o.total})">💠 Pagar via Pix agora</button>
      </div>`;
    }).join('');
  } else {
    html += '<div class="ok-box" style="font-size:14px">🎉 Nenhuma pendência em aberto. Você está em dia!</div>';
  }

  document.getElementById('extrato-content').innerHTML = html;
}

function openClientPix(oid, total) {
  document.getElementById('cpix-b').innerHTML = `
    <div class="info-box">Pagamento de <strong>${fmt(total)}</strong></div>
    <div class="pix-box" style="text-align:center">
      <div class="ts tl" style="margin-bottom:5px">Chave Pix CNPJ — Mãos que Encantam</div>
      <div class="pix-key" onclick="navigator.clipboard.writeText('${D.cfg.pix || ''}').then(()=>toast('Copiado!','ok'))">${D.cfg.pix || '36.120.504/0001-92'}</div>
      <div class="ts tl">Favorecida: ${D.cfg.pixName || 'Helena Aparecida Gobato'}<br>Toque para copiar</div>
    </div>
    <div class="fg mt3">
      <label class="fl">Anexar comprovante</label>
      <div class="upload-box" onclick="document.getElementById('cpix-comp').click()">
        <input type="file" id="cpix-comp" accept="image/*,.pdf" style="display:none" onchange="handleClientPixComp(this,'${oid}')">
        <div style="font-size:22px;margin-bottom:5px">📎</div>
        <div class="tm tl" id="cpix-lbl">Toque para anexar comprovante</div>
      </div>
    </div>
    <div class="warn-box">Após enviar, aguarde o vendedor confirmar.</div>`;
  openOv('ov-cpix');
}

function handleClientPixComp(input, oid) {
  const f = input.files[0];
  if (!f) return;
  const o = D.orders.find(x => x.id === oid);
  if (o) { o.comprovante = f.name; save(); }
  document.getElementById('cpix-lbl').textContent = '✅ ' + f.name;
  toast('Comprovante enviado! Aguarde confirmação.', 'ok');
}

// ===================== RATINGS =====================
function openRateModal(oid) {
  document.getElementById('rate-id').value = oid;
  setRating(5);
  openOv('ov-rate');
}

function setRating(n) {
  document.getElementById('rate-v').value = n;
  document.getElementById('star-btns').innerHTML = [1, 2, 3, 4, 5].map(i =>
    `<button class="star-btn ${i <= n ? 'on' : ''}" type="button" onclick="setRating(${i})">⭐</button>`
  ).join('');
  document.getElementById('rate-lbl').textContent = RATE_LABELS[n] || '';
}

function submitRate() {
  const oid = document.getElementById('rate-id').value;
  const n = parseInt(document.getElementById('rate-v').value);
  const o = D.orders.find(x => x.id === oid);
  if (o) { o.rating = n; save(); }
  closeOv('ov-rate');
  renderMyOrders();
  toast('Avaliação enviada! ⭐', 'ok');
}

// ===================== KEYBOARD =====================
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter') {
    const admLogin = document.getElementById('adm-login');
    const cliLogin = document.getElementById('cli-login');
    if (admLogin && admLogin.classList.contains('active')) doAdmLogin();
    else if (cliLogin && cliLogin.classList.contains('active')) doCliLogin();
  }
  if (e.key === 'Escape') {
    document.querySelectorAll('.ov.on').forEach(o => o.classList.remove('on'));
  }
});

// ===================== INIT =====================
(function init() {
  showPage('pg-land');
})();
</script>
