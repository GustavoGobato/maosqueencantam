.cn{padding:7px 12px;border-radius:var(--r8);font-size:12px;font-weight:600;cursor:pointer;border:none;color:rgba(255,255,255,.5);background:transparent;transition:all .17s;white-space:nowrap}
.cn:hover{background:rgba(255,255,255,.09);color:rgba(255,255,255,.85)}
.cn.on{background:linear-gradient(135deg,rgba(184,134,11,.4),rgba(160,82,45,.3));color:#fff}
.cli-body{padding:22px 20px;max-width:760px;margin:0 auto}
.cs{display:none}.cs.on{display:block}
.cli-greet-name{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--ink);margin-bottom:3px}
.cli-greet-sub{font-size:13px;color:var(--t3);margin-bottom:20px}
/* CATALOG */
.cat-g{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-bottom:22px}
.cat-item{background:var(--paper);border-radius:var(--r16);border:1.5px solid var(--bege);padding:18px 13px;text-align:center;cursor:pointer;transition:all .22s;box-shadow:var(--sh1);position:relative}
.cat-item:hover{transform:translateY(-3px);box-shadow:var(--sh2);border-color:var(--bege-d)}
.cat-item.sel{border-color:var(--copper);background:rgba(160,82,45,.05);box-shadow:0 4px 16px rgba(160,82,45,.15)}
.cat-emoji{font-size:32px;margin-bottom:9px;display:block}
