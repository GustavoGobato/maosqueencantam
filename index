  const titles = {
    dashboard: 'Dashboard', orders: 'Pedidos', fiado: 'Fiado',
    products: 'Produtos', discounts: 'Descontos', schedule: 'Agenda',
    cashflow: 'Fluxo de Caixa', reports: 'Relatórios',
    clients: 'Clientes', sellers: 'Vendedores', settings: 'Configurações'
  };
  document.getElementById('adm-ht').textContent = titles[name] || name;

  const renders = {
    dashboard: renderDash, orders: () => renderOrders('all'),
