<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Mãos que Encantam</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#1A0F0A;--ink-m:#3D2316;--ink-l:#6B4030;
  --cream:#FAF6F0;--paper:#FDF9F4;--linen:#F2EBE0;
  --bege:#E5D8C5;--bege-d:#C8B49A;--bege-dk:#A8947A;
  --gold:#B8860B;--gold-l:#D4A020;--gold-ll:#E8C060;
  --copper:#A0522D;--copper-l:#C06838;
  --rose:#C25050;--sage:#4A6741;--sage-l:#5D8054;
  --amber:#C07820;--err:#B83030;
  --t1:#1A0F0A;--t2:#4A2E1E;--t3:#7A5040;--t4:#B08060;
  --sh1:0 1px 4px rgba(26,15,10,.06);--sh2:0 4px 20px rgba(26,15,10,.1);
  --sh3:0 8px 40px rgba(26,15,10,.16);--sh4:0 20px 80px rgba(26,15,10,.24);
  --r4:4px;--r8:8px;--r12:12px;--r16:16px;--r24:24px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{font-size:16px}
body{font-family:'Outfit',sans-serif;background:var(--cream);color:var(--t1);min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased}
/* PAGES - all hidden by default */
.page{display:none}
.page.active{display:flex;flex-direction:column}
#pg-land.active{align-items:center;justify-content:center;min-height:100vh;background:var(--paper);padding:48px 24px;position:relative;overflow:hidden}
#pg-admin.active{flex-direction:row;min-height:100vh}
#pg-client.active{min-height:100vh;background:var(--cream)}
.auth-page{align-items:center;justify-content:center;min-height:100vh;background:var(--paper)}
/* TOAST */
#toasts{position:fixed;top:16px;right:16px;z-index:10000;display:flex;flex-direction:column;gap:8px;pointer-events:none;max-width:300px}
.toast{background:var(--ink);color:var(--paper);padding:12px 18px;border-radius:var(--r8);font-size:13px;font-weight:500;box-shadow:var(--sh3);animation:tIn .3s cubic-bezier(.34,1.56,.64,1);pointer-events:all;line-height:1.4}
.toast.ok{background:var(--sage)}.toast.err{background:var(--err)}.toast.warn{background:var(--amber);color:#fff}
@keyframes tIn{from{transform:translateX(120%);opacity:0}to{transform:translateX(0);opacity:1}}
/* MODAL */
.ov{display:none;position:fixed;inset:0;background:rgba(26,15,10,.65);backdrop-filter:blur(6px);z-index:800;align-items:flex-end;justify-content:center}
.ov.on{display:flex}
@media(min-width:640px){.ov{align-items:center;padding:20px}}
.modal{background:var(--paper);border-radius:var(--r24) var(--r24) 0 0;padding:28px 24px 40px;width:100%;max-width:520px;max-height:92vh;overflow-y:auto;position:relative;animation:mUp .3s cubic-bezier(.34,1.1,.64,1)}
@media(min-width:640px){.modal{border-radius:var(--r24);padding:36px 32px}}
@keyframes mUp{from{transform:translateY(50px);opacity:0}to{transform:translateY(0);opacity:1}}
.m-handle{width:40px;height:4px;background:var(--bege-d);border-radius:2px;margin:0 auto 18px;display:block}
@media(min-width:640px){.m-handle{display:none}}
.m-title{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--ink);margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--bege)}
.m-x{position:absolute;top:14px;right:16px;background:none;border:none;font-size:22px;color:var(--t4);cursor:pointer;padding:4px;line-height:1;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:var(--r8)}
.m-x:hover{background:var(--linen)}
/* FORMS */
.fg{margin-bottom:14px}
.fl{display:block;font-size:11px;font-weight:700;color:var(--t3);margin-bottom:7px;letter-spacing:.07em;text-transform:uppercase}
.fi,.fs,.fta{width:100%;padding:11px 14px;border:1.5px solid var(--bege);border-radius:var(--r8);background:var(--paper);font-family:'Outfit',sans-serif;font-size:14px;color:var(--t1);outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
.fi:focus,.fs:focus,.fta:focus{border-color:var(--copper);box-shadow:0 0 0 3px rgba(160,82,45,.12)}
.fta{resize:vertical;min-height:80px}
.f2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:440px){.f2{grid-template-columns:1fr}}
.pw-w{position:relative}
.pw-t{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--t4);padding:2px}
.fhint{font-size:11px;color:var(--t4);margin-top:5px}
/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;padding:11px 22px;border-radius:var(--r8);font-family:'Outfit',sans-serif;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .2s;white-space:nowrap;-webkit-appearance:none}
.btn-ink{background:var(--ink);color:var(--paper);box-shadow:0 2px 10px rgba(26,15,10,.22)}
.btn-ink:hover{background:var(--ink-m);transform:translateY(-1px)}
.btn-gold{background:linear-gradient(135deg,var(--gold-l),var(--copper));color:#fff;box-shadow:0 2px 12px rgba(184,134,11,.3)}
.btn-gold:hover{transform:translateY(-1px);box-shadow:0 4px 18px rgba(184,134,11,.4)}
.btn-out{background:transparent;color:var(--ink);border:1.5px solid var(--bege-d)}
.btn-out:hover{background:var(--linen)}
.btn-sage{background:var(--sage);color:#fff}
.btn-err{background:var(--err);color:#fff}
.btn-wa{background:#25D366;color:#fff}
.btn-amber{background:var(--amber);color:#fff}
.btn-sm{padding:7px 14px;font-size:12px}
.btn-full{width:100%}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}
/* BADGE */
.bdg{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;gap:4px}
.b-pend{background:#FEF3C7;color:#92400E}.b-conf{background:#D1FAE5;color:#065F46}
.b-ready{background:#DBEAFE;color:#1E40AF}.b-done{background:#E5E7EB;color:#374151}
.b-canc{background:#FEE2E2;color:#991B1B}.b-pix{background:#EDE9FE;color:#4C1D95}
.b-cash{background:#ECFDF5;color:#065F46}.b-fiado{background:#FEF3C7;color:#92400E}
.b-paid{background:#D1FAE5;color:#065F46}.b-unpaid{background:#FEE2E2;color:#991B1B}
.b-over{background:#EF4444;color:#fff;animation:bl 1.4s infinite}
.b-ok{background:#D1FAE5;color:#065F46}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.5}}
/* ALERTS */
.warn-box{background:#FFFBEB;border:1px solid #FDE68A;border-left:3px solid var(--amber);border-radius:var(--r8);padding:11px 14px;font-size:12.5px;color:#78350F;margin-bottom:12px;line-height:1.5}
.info-box{background:#EFF6FF;border:1px solid #BFDBFE;border-left:3px solid #3B82F6;border-radius:var(--r8);padding:11px 14px;font-size:12.5px;color:#1E40AF;margin-bottom:12px;line-height:1.5}
.ok-box{background:#F0FDF4;border:1px solid #BBF7D0;border-left:3px solid var(--sage);border-radius:var(--r8);padding:11px 14px;font-size:12.5px;color:#14532D;margin-bottom:12px;line-height:1.5}
.err-msg{background:#FEF2F2;border:1px solid #FECACA;border-left:3px solid var(--err);border-radius:var(--r8);padding:11px 14px;font-size:12.5px;color:#7F1D1D;margin-bottom:12px;display:none}
/* LANDING */
.land-bg{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.land-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.4}
.land-deco{position:absolute;font-size:180px;opacity:.04;pointer-events:none;user-select:none}
.land-mon{width:80px;height:80px;background:linear-gradient(135deg,var(--ink),var(--ink-m));border-radius:22px;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:0 10px 40px rgba(26,15,10,.3);font-family:'Playfair Display',serif;font-style:italic;font-size:36px;color:var(--gold-ll)}
.land-title{font-family:'Playfair Display',serif;font-size:clamp(26px,6vw,42px);font-weight:900;color:var(--ink);text-align:center;line-height:1.1;margin-bottom:8px;letter-spacing:-.02em}
.land-sub{font-size:15px;color:var(--t3);text-align:center;margin-bottom:50px;font-style:italic;font-family:'Playfair Display',serif}
.closed-strip{background:#FEE2E2;border:1px solid #FCA5A5;border-radius:var(--r8);padding:12px 20px;font-size:13px;font-weight:600;color:var(--err);text-align:center;margin-bottom:24px;max-width:500px;width:100%;display:none}
.cards-wrap{display:flex;gap:20px;flex-wrap:wrap;justify-content:center;max-width:640px;width:100%;position:relative}
.land-card{flex:1;min-width:230px;max-width:290px;background:var(--paper);border-radius:var(--r24);padding:36px 28px;border:1px solid var(--bege);box-shadow:var(--sh2);cursor:pointer;transition:all .25s;text-align:center}
.land-card:hover{transform:translateY(-6px);box-shadow:var(--sh4);border-color:var(--bege-d)}
.land-card.adm{border-top:3px solid var(--gold-l)}.land-card.cli{border-top:3px solid var(--rose)}
.lc-badge{display:inline-flex;align-items:center;justify-content:center;width:58px;height:58px;border-radius:16px;margin:0 auto 16px;font-size:26px}
.lc-badge.adm{background:linear-gradient(135deg,rgba(184,134,11,.12),rgba(160,82,45,.12))}
.lc-badge.cli{background:linear-gradient(135deg,rgba(194,80,80,.1),rgba(217,104,104,.1))}
.lc-title{font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:var(--ink);margin-bottom:8px}
.lc-desc{font-size:13px;color:var(--t3);line-height:1.6}
.lc-arr{font-size:12px;color:var(--t4);margin-top:14px;font-weight:600;transition:all .2s}
.land-card:hover .lc-arr{color:var(--copper)}
/* AUTH */
.auth-box{background:var(--paper);border:1px solid var(--bege);border-radius:var(--r24);padding:44px 36px;width:100%;max-width:420px;box-shadow:var(--sh3);position:relative;margin:20px}
@media(max-width:480px){.auth-box{padding:36px 24px;margin:16px}}
.auth-back{position:absolute;top:14px;left:16px;background:none;border:none;width:36px;height:36px;border-radius:var(--r8);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t4);font-size:18px;transition:all .18s}
.auth-back:hover{background:var(--linen);color:var(--ink)}
.auth-icon-wrap{text-align:center;margin-bottom:16px}
.auth-icon-inner{display:inline-flex;align-items:center;justify-content:center;width:62px;height:62px;border-radius:18px;font-size:28px;background:linear-gradient(135deg,var(--linen),var(--bege));border:1px solid var(--bege)}
.auth-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:var(--ink);text-align:center;margin-bottom:5px}
.auth-sub{font-size:13px;color:var(--t3);text-align:center;margin-bottom:26px}
.divider-txt{text-align:center;font-size:12px;color:var(--t4);margin:16px 0;position:relative}
.divider-txt::before,.divider-txt::after{content:'';position:absolute;top:50%;width:38%;height:1px;background:var(--bege)}
.divider-txt::before{left:0}.divider-txt::after{right:0}
/* ADMIN LAYOUT */
.sidebar{width:240px;background:var(--ink);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:200;transition:transform .3s;box-shadow:4px 0 30px rgba(26,15,10,.25)}
.sb-top{padding:24px 20px 18px;border-bottom:1px solid rgba(255,255,255,.07)}
.sb-brand{display:flex;align-items:center;gap:12px}
.sb-logo-box{width:38px;height:38px;background:linear-gradient(135deg,var(--gold-l),var(--copper));border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-style:italic;font-size:18px;color:var(--paper);flex-shrink:0;box-shadow:0 2px 10px rgba(184,134,11,.35)}
.sb-name{font-family:'Playfair Display',serif;font-size:13px;font-weight:700;color:rgba(255,255,255,.9);line-height:1.3}
.sb-tag{font-size:10px;color:rgba(255,255,255,.3);margin-top:1px}
.sb-nav{flex:1;padding:14px 12px;overflow-y:auto;scrollbar-width:none}
.sb-nav::-webkit-scrollbar{display:none}
.sb-gl{font-size:9px;font-weight:700;color:rgba(255,255,255,.2);letter-spacing:.1em;text-transform:uppercase;padding:10px 10px 5px;margin-top:4px}
.ni{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--r8);color:rgba(255,255,255,.5);font-size:12.5px;font-weight:500;cursor:pointer;transition:all .17s;margin-bottom:2px;border:none;background:none;width:100%;text-align:left;position:relative}
.ni:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.85)}
.ni.on{background:linear-gradient(135deg,rgba(184,134,11,.3),rgba(160,82,45,.2));color:#fff}
.ni.on::before{content:'';position:absolute;left:0;top:22%;bottom:22%;width:2.5px;background:var(--gold-l);border-radius:0 2px 2px 0}
.ni-ico{width:18px;text-align:center;font-size:15px;flex-shrink:0}
.ni-b{margin-left:auto;background:var(--rose);color:#fff;font-size:10px;font-weight:800;padding:2px 6px;border-radius:10px}
.sb-bot{padding:14px 12px;border-top:1px solid rgba(255,255,255,.07)}
.sb-profile{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:var(--r8);background:rgba(255,255,255,.06);margin-bottom:9px;border:1px solid rgba(255,255,255,.05)}
.sb-av{width:32px;height:32px;background:linear-gradient(135deg,var(--gold-l),var(--copper));border-radius:var(--r8);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0}
.sb-uname{font-size:12.5px;font-weight:600;color:rgba(255,255,255,.9)}
.sb-urole{font-size:10px;color:rgba(255,255,255,.35);margin-top:1px}
.adm-main{margin-left:240px;flex:1;background:var(--cream);min-height:100vh;display:flex;flex-direction:column}
.adm-hdr{background:var(--paper);border-bottom:1px solid var(--bege);padding:0 28px;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;gap:12px}
.adm-ht{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--ink)}
.adm-hr{display:flex;align-items:center;gap:8px}
.adm-cnt{padding:26px}
.hbg{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;border-radius:var(--r8)}
.hbg:hover{background:var(--linen)}
.hbg span{width:20px;height:2px;background:var(--ink);border-radius:2px;display:block}
.sb-ov{display:none;position:fixed;inset:0;background:rgba(26,15,10,.5);backdrop-filter:blur(4px);z-index:199}
.sb-ov.on{display:block}
/* ADMIN SECTIONS */
.adm-s{display:none}.adm-s.on{display:block}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.st{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--ink)}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-bottom:24px}
.sc{background:var(--paper);border-radius:var(--r16);padding:20px;border:1px solid var(--bege);box-shadow:var(--sh1);transition:all .2s}
.sc:hover{box-shadow:var(--sh2);transform:translateY(-2px)}
.sc-ico{font-size:22px;margin-bottom:9px;display:block}
.sc-v{font-family:'Playfair Display',serif;font-size:26px;font-weight:900;color:var(--ink);line-height:1;letter-spacing:-.02em}
.sc-l{font-size:11px;color:var(--t4);margin-top:4px;font-weight:500}
.tw{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);box-shadow:var(--sh1);overflow:hidden;overflow-x:auto}
table{width:100%;border-collapse:collapse;min-width:480px}
th{background:var(--linen);padding:11px 15px;font-size:10.5px;font-weight:700;color:var(--t2);letter-spacing:.07em;text-transform:uppercase;text-align:left;white-space:nowrap;border-bottom:1px solid var(--bege)}
td{padding:12px 15px;font-size:13px;border-bottom:1px solid rgba(229,216,197,.5);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(242,235,224,.4)}
.tabs{display:flex;gap:3px;background:var(--linen);border-radius:var(--r12);padding:4px;margin-bottom:18px;overflow-x:auto;scrollbar-width:none;border:1px solid var(--bege)}
.tabs::-webkit-scrollbar{display:none}
.tab{flex:1;min-width:fit-content;padding:7px 13px;border-radius:var(--r8);border:none;background:transparent;font-size:12px;font-weight:600;cursor:pointer;color:var(--t3);transition:all .18s;white-space:nowrap}
.tab.on{background:var(--paper);color:var(--ink);box-shadow:var(--sh1)}
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:15px}
.pc{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);box-shadow:var(--sh1);padding:22px;transition:all .2s}
.pc:hover{box-shadow:var(--sh2);transform:translateY(-3px)}
.pc-em{font-size:38px;margin-bottom:11px;display:block}
.pc-name{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--ink);margin-bottom:4px}
.pc-price{font-size:20px;font-weight:700;color:var(--copper);margin-bottom:6px;font-family:'Playfair Display',serif}
.pc-desc{font-size:12px;color:var(--t4);margin-bottom:14px;line-height:1.5}
.pc-acts{display:flex;gap:8px}
.li{background:var(--paper);border-radius:var(--r12);border:1px solid var(--bege);padding:14px 17px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:9px;transition:all .17s}
.li:hover{box-shadow:var(--sh1);border-color:var(--bege-d)}
.li.fi-od{border-left:3px solid var(--err)}.li.fi-ok{border-left:3px solid var(--sage-l)}
.li-code{font-family:monospace;font-size:14px;font-weight:700;color:var(--ink)}
.li-info{font-size:12px;color:var(--t4);margin-top:3px;line-height:1.5}
.li-acts{display:flex;gap:7px;flex-shrink:0;flex-wrap:wrap;justify-content:flex-end;align-items:center}
.cfc{display:grid;grid-template-columns:repeat(3,1fr);gap:13px;margin-bottom:20px}
@media(max-width:600px){.cfc{grid-template-columns:1fr}}
.cfc-c{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);padding:18px;text-align:center}
.cfc-v{font-family:'Playfair Display',serif;font-size:24px;font-weight:900;margin-bottom:4px;letter-spacing:-.02em}
.cfc-l{font-size:11px;color:var(--t4);font-weight:500;letter-spacing:.02em}
.c-pos{color:var(--sage)}.c-war{color:var(--amber)}.c-ink{color:var(--ink)}
.pb-w{height:7px;background:var(--bege);border-radius:4px;overflow:hidden;margin-top:7px}
.pb{height:100%;background:linear-gradient(90deg,var(--gold-l),var(--copper));border-radius:4px;transition:width .6s}
.perm-g{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.perm-c{display:flex;align-items:center;gap:8px;font-size:12.5px;cursor:pointer;padding:9px 12px;border:1.5px solid var(--bege);border-radius:var(--r8);transition:all .17s;user-select:none}
.perm-c:hover{border-color:var(--bege-d);background:var(--linen)}
.perm-c.ck{border-color:var(--copper);background:rgba(160,82,45,.06);color:var(--copper)}
.perm-c input{accent-color:var(--copper);width:14px;height:14px}
@media(max-width:460px){.perm-g{grid-template-columns:1fr}}
.store-tgl{display:inline-flex;align-items:center;gap:12px;padding:12px 18px;border-radius:var(--r12);border:1.5px solid var(--bege);background:var(--paper);cursor:pointer;transition:all .2s;margin-bottom:18px;box-shadow:var(--sh1)}
.store-tgl.open{border-color:rgba(74,103,65,.35);background:rgba(74,103,65,.05)}
.store-tgl.closed{border-color:rgba(184,48,48,.35);background:rgba(184,48,48,.05)}
.tgl-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0}
.tgl-dot.open{background:var(--sage-l)}.tgl-dot.closed{background:var(--err)}
.tgl-txt{font-size:13px;font-weight:600}
.tgl-sub{font-size:11px;color:var(--t4);margin-top:1px}
.goal-w{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);padding:18px 20px;margin-bottom:18px;box-shadow:var(--sh1)}
.sc-card{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);padding:20px;margin-bottom:14px;box-shadow:var(--sh1)}
/* CLIENT AREA */
.cli-hdr{background:var(--ink);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(26,15,10,.25)}
