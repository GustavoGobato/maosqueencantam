  html += '<div class="sc-card"><div class="st m4">📋 Histórico de Preços</div>';
  if (!ph.length) html += '<div class="empty"><span class="empty-ico">💲</span><div class="empty-txt">Nenhuma alteração registrada.</div></div>';
  else html += `<div class="tw"><table><thead><tr><th>Produto</th><th>Preço Anterior</th><th>Novo Preço</th><th>Data</th></tr></thead><tbody>${ph.slice(0, 30).map(r => `<tr><td>${r.product}</td><td style="text-decoration:line-through;color:var(--t4)">${fmt(r.oldPrice)}</td><td><strong style="color:var(--copper)">${fmt(r.newPrice)}</strong></td><td>${fmtDate(r.date)}</td></tr>`).join('')}</tbody></table></div>`;
  html += '</div>';

  const ratings = D.orders.filter(o => o.rating);
