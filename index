.pix-key:hover{border-color:var(--copper)}
.upload-box{border:2px dashed var(--bege-d);border-radius:var(--r12);padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:var(--cream);margin-top:10px}
.upload-box:hover{border-color:var(--copper);background:rgba(160,82,45,.03)}
/* ORDERS */
.ord-card{background:var(--paper);border-radius:var(--r16);border:1px solid var(--bege);padding:17px;margin-bottom:11px;box-shadow:var(--sh1);transition:all .17s}
.ord-card:hover{box-shadow:var(--sh2)}
/* EXTRATO */
.ext-hero{background:linear-gradient(135deg,var(--ink),var(--ink-m));border-radius:var(--r16);padding:24px;margin-bottom:14px;color:#fff;position:relative;overflow:hidden}
.ext-hero-lbl{font-size:11px;color:rgba(255,255,255,.45);letter-spacing:.06em;text-transform:uppercase;margin-bottom:5px}
.ext-hero-v{font-family:'Playfair Display',serif;font-size:34px;font-weight:900;color:var(--gold-ll);letter-spacing:-.02em}
.ext-hero-sub{font-size:12px;color:rgba(255,255,255,.45);margin-top:5px}
.ext-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
/* FAV CHIPS */
.fav-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 13px;border-radius:20px;background:var(--paper);border:1.5px solid var(--bege);font-size:12px;cursor:pointer;margin:3px;transition:all .2s;font-weight:500;box-shadow:var(--sh1)}
.fav-chip:hover{border-color:var(--copper);transform:translateY(-1px)}
/* RATING */
.star-btn{background:none;border:none;font-size:30px;cursor:pointer;padding:4px;transition:transform .15s;opacity:.35;filter:grayscale(1)}
.star-btn.on{filter:grayscale(0);opacity:1;transform:scale(1.08)}
/* UTILS */
.flex{display:flex}.ic{align-items:center}.jb{justify-content:space-between}.g2{gap:8px}.g3{gap:12px}
.m1{margin-bottom:4px}.m2{margin-bottom:8px}.m3{margin-bottom:12px}.m4{margin-bottom:16px}.m5{margin-bottom:20px}.m6{margin-bottom:24px}
.mt2{margin-top:8px}.mt3{margin-top:12px}.mt4{margin-top:16px}
.ts{font-size:12px}.tm{font-size:13px}.tl{color:var(--t4)}.tc{color:var(--ink)}.fw7{font-weight:700}
.empty{text-align:center;padding:50px 20px;color:var(--t4)}
.empty-ico{font-size:44px;margin-bottom:13px;opacity:.35;display:block}
.empty-txt{font-size:14px;line-height:1.6}
/* RESPONSIVE */
@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}.sidebar.on{transform:translateX(0)}
  .adm-main{margin-left:0}.adm-cnt{padding:15px}.adm-hdr{padding:0 15px}
  .hbg{display:flex}.sg{grid-template-columns:repeat(2,1fr)}
