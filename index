.pay-opts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0}
.po{padding:12px 7px;border-radius:var(--r12);border:1.5px solid var(--bege);background:var(--paper);text-align:center;cursor:pointer;transition:all .2s;font-size:12px;font-weight:600;color:var(--t3)}
