        <button class="btn btn-err btn-sm" onclick="deleteProd('${p.id}')">🗑</button>
      </div>
    </div>`).join('');
}

function openPM(id) {
  const p = id ? D.products.find(x => x.id === id) : null;
  document.getElementById('pm-t').textContent = p ? 'Editar Produto' : 'Novo Produto';
  document.getElementById('pm-id').value = p ? p.id : '';
  document.getElementById('pm-n').value = p ? p.name : '';
  document.getElementById('pm-e').value = p ? p.emoji : '🍬';
  document.getElementById('pm-p').value = p ? p.price : '';
  document.getElementById('pm-d').value = p ? (p.desc || '') : '';
  openOv('ov-prod');
}

function saveProd() {
  const id = document.getElementById('pm-id').value;
  const name = document.getElementById('pm-n').value.trim();
  const emoji = document.getElementById('pm-e').value.trim() || '🍬';
  const price = parseFloat(document.getElementById('pm-p').value);
  const desc = document.getElementById('pm-d').value.trim();
  if (!name || isNaN(price) || price <= 0) { toast('Nome e preço válido obrigatórios.', 'err'); return; }

  if (id) {
    const p = D.products.find(x => x.id === id);
    if (p && p.price !== price) {
      if (!D.cfg.priceHistory) D.cfg.priceHistory = [];
      D.cfg.priceHistory.unshift({ product: p.name, oldPrice: p.price, newPrice: price, date: new Date().toISOString() });
    }
    if (p) Object.assign(p, { name, emoji, price, desc });
  } else {
    D.products.push({ id: uid(), name, emoji, price, desc });
  }
  save(); closeOv('ov-prod'); renderProducts(); toast('Produto salvo!', 'ok');
}

function deleteProd(id) {
  if (!confirm('Excluir este produto?')) return;
  D.products = D.products.filter(x => x.id !== id);
  save(); renderProducts(); toast('Produto removido.', 'warn');
}

// ===================== DISCOUNTS =====================
function renderDiscounts() {
  const el = document.getElementById('disc-l');
  if (!D.discounts.length) {
    el.innerHTML = '<div class="empty"><span class="empty-ico">🏷️</span><div class="empty-txt">Nenhum código.</div></div>';
    return;
  }
  el.innerHTML = D.discounts.map(d => `
    <div class="li">
      <div>
        <div class="li-code">${d.code}</div>
        <div class="li-info">${d.type === 'percent' ? d.value + '% de desconto' : fmt(d.value) + ' de desconto'} · ${d.maxUse > 0 ? d.used + '/' + d.maxUse + ' usos' : 'Ilimitado'}</div>
      </div>
      <div class="li-acts">
        <span class="fw7" style="color:var(--copper);font-family:'Playfair Display',serif">${d.type === 'percent' ? d.value + '%' : fmt(d.value)}</span>
        <button class="btn btn-err btn-sm" onclick="deleteDisc('${d.id}')">🗑</button>
      </div>
    </div>`).join('');
