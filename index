function saveSeller() {
  const id = document.getElementById('sel-id').value;
  const name = document.getElementById('sel-n').value.trim();
  const user = document.getElementById('sel-u').value.trim().toLowerCase();
  const pass = document.getElementById('sel-p').value;
  if (!name || !user) { toast('Nome e usuário obrigatórios.', 'err'); return; }
  if (!id && (!pass || pass.length < 6)) { toast('Senha mínimo 6 caracteres.', 'err'); return; }
  if (user === ADM_USER) { toast('Este usuário é reservado.', 'err'); return; }
  const permissions = [1, 2, 3, 4, 5, 6].filter(n => document.getElementById('p' + n).checked).map(n => document.getElementById('p' + n).value);
  if (id) {
    const s = D.sellers.find(x => x.id === id);
    if (s) { Object.assign(s, { name, username: user, permissions }); if (pass) s.password = pass; }
  } else {
    if (D.sellers.find(s => s.username === user) || D.clients.find(c => c.username === user)) { toast('Usuário já em uso.', 'err'); return; }
    D.sellers.push({ id: uid(), name, username: user, password: pass, permissions, active: true });
  }
  save(); closeOv('ov-seller'); renderSellers(); toast('Vendedor salvo!', 'ok');
}

function deleteSeller(id) {
  if (!confirm('Remover este vendedor?')) return;
  D.sellers = D.sellers.filter(x => x.id !== id);
  save(); renderSellers(); toast('Removido.', 'warn');
}

