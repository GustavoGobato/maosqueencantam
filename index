}

function confirmFP() {
  const id = document.getElementById('fp-id').value;
  markOrderPaid(id);
  closeOv('ov-fp');
  renderFiado();
  toast('Fiado quitado! 🎉', 'ok');
}

// ===================== PRODUCTS =====================
function renderProducts() {
  const g = document.getElementById('prod-g');
  if (!D.products.length) {
    g.innerHTML = '<div class="empty"><span class="empty-ico">🍬</span><div class="empty-txt">Nenhum produto.</div></div>';
    return;
  }
