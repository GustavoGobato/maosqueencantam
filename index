}

function fOrds(f, btn) {
  document.querySelectorAll('#ord-tabs .tab').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  renderOrders(f);
}

function openOrderDetail(id) {
  const o = D.orders.find(x => x.id === id);
  if (!o) return;
  const c = D.clients.find(x => x.id === o.clientId);
  const isAdmin = SESSION.type === 'admin';
  const canUpdate = isAdmin || (SESSION.perms || []).includes('update-orders');

  const itemsHTML = (o.items || []).map(i =>
    `<div class="cart-item-row"><span class="cir-name">${i.qty}× ${i.emoji || ''} ${i.name}</span><span class="cir-price">${fmt(i.price * i.qty)}</span></div>`
  ).join('');

  const cashNote = o.payment === 'dinheiro' && o.paymentStatus === 'unpaid'
    ? `<div class="warn-box mt3">💵 <strong>Dinheiro na retirada.</strong> Confirme o recebimento presencialmente antes de marcar como pago.</div>` : '';
  const fiadoNote = o.payment === 'fiado'
    ? `<div class="warn-box mt3">📒 Fiado · Vencimento: <strong>${o.fiadoDate ? fmtDate(o.fiadoDate) : 'Não definido'}</strong>${isOverdue(o) ? ' <span style="color:var(--err);font-weight:700">— VENCIDO</span>' : ''}</div>` : '';
  const stars = o.rating ? '⭐'.repeat(o.rating) : '<span class="tl ts">Não avaliado</span>';

  document.getElementById('od-t').textContent = `Pedido #${o.num}`;
  document.getElementById('od-b').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
      <div><div class="ts tl m1">Cliente</div><div class="fw7">${c ? c.name : '-'}</div><div class="ts tl">${c ? (c.phone || '') : ''}</div></div>
      <div><div class="ts tl m1">Data</div><div>${fmtDate(o.date)}</div>${o.pickupDate ? `<div class="ts tl">Retirada: ${fmtDate(o.pickupDate)}</div>` : ''}</div>
    </div>
    <div style="height:1px;background:var(--bege);margin:13px 0"></div>
    ${itemsHTML}
    ${o.discount ? `<div class="cart-item-row"><span style="color:var(--sage)">🏷️ ${o.discount.code}</span><span style="color:var(--sage);font-weight:700">-${fmt(o.discount.amount)}</span></div>` : ''}
    <div class="cart-total-row"><span class="ctl">Total</span><span class="ctv">${fmt(o.total)}</span></div>
    <div class="flex g2 mt3" style="flex-wrap:wrap">${payBadge(o.payment)} ${paidBadge(o.paymentStatus)} ${statusBadge(o.status)}</div>
    ${cashNote}${fiadoNote}
    ${o.obs ? `<div class="mt3"><div class="ts tl m1">Observações</div><div style="background:var(--linen);padding:10px 12px;border-radius:var(--r8);font-size:13px;border:1px solid var(--bege)">${o.obs}</div></div>` : ''}
    ${o.comprovante ? `<div class="mt3"><div class="ok-box">✅ Comprovante: ${o.comprovante}</div></div>` : ''}
    <div class="mt3"><div class="ts tl m1">Avaliação</div><div style="font-size:18px">${stars}</div></div>`;

  let acts = '';
  if (canUpdate) {
    if (o.status === 'pending') acts += `<button class="btn btn-ink btn-sm" onclick="updateOrderStatus('${o.id}','confirmed')">✓ Confirmar</button>`;
    if (o.status === 'confirmed') acts += `<button class="btn btn-ink btn-sm" onclick="updateOrderStatus('${o.id}','ready')">📦 Pronto</button>`;
    if (o.status === 'ready') acts += `<button class="btn btn-ink btn-sm" onclick="updateOrderStatus('${o.id}','done')">✅ Entregar</button>`;
    if (o.paymentStatus === 'unpaid') {
      if (o.payment === 'dinheiro') acts += `<button class="btn btn-sage btn-sm" onclick="markOrderPaid('${o.id}')">💵 Confirmar Dinheiro</button>`;
      else if (o.payment === 'fiado') acts += `<button class="btn btn-sage btn-sm" onclick="openFiadoPay('${o.id}')">💰 Fiado Pago</button>`;
      else acts += `<button class="btn btn-sage btn-sm" onclick="markOrderPaid('${o.id}')">✓ Marcar Pago</button>`;
    }
    if (o.payment === 'fiado' && o.paymentStatus === 'unpaid') {
      acts += `<button class="btn btn-wa btn-sm" onclick="sendWhatsApp('${o.id}')">📲 Cobrar WA</button>`;
    }
  }
  if (isAdmin) acts += `<button class="btn btn-err btn-sm" onclick="deleteOrder('${o.id}')">🗑 Excluir</button>`;
  document.getElementById('od-a').innerHTML = acts;
  openOv('ov-ord');
}

function updateOrderStatus(id, status) {
  const o = D.orders.find(x => x.id === id);
  if (!o) return;
  o.status = status;
  save(); updateBadges(); closeOv('ov-ord'); renderOrders(ORD_FILTER);
  toast('Status atualizado!', 'ok');
}

function markOrderPaid(id) {
  const o = D.orders.find(x => x.id === id);
  if (!o) return;
  o.paymentStatus = 'paid';
  save(); closeOv('ov-ord'); renderOrders(ORD_FILTER); renderDash(); updateBadges();
  toast('Pagamento confirmado! 💰', 'ok');
}

function deleteOrder(id) {
  if (!confirm('Excluir este pedido permanentemente?')) return;
  D.orders = D.orders.filter(x => x.id !== id);
  save(); closeOv('ov-ord'); renderOrders(ORD_FILTER); renderDash(); updateBadges();
  toast('Pedido excluído.', 'warn');
}

function sendWhatsApp(id) {
  const o = D.orders.find(x => x.id === id);
  if (!o) return;
  const c = D.clients.find(x => x.id === o.clientId);
  if (!c) return;
  const phone = (c.phone || '').replace(/\D/g, '');
  const items = (o.items || []).map(i => `${i.qty}x ${i.name}`).join(', ');
  const msg = `Olá, ${c.name.split(' ')[0]}! 👋\n\nPassando para lembrar do seu pedido em aberto na *Mãos que Encantam* 🍰\n\n📦 *Pedido #${o.num}*\n${items}\n\n💰 Valor: *${fmt(o.total)}*\n📅 Vencimento: ${o.fiadoDate ? fmtDate(o.fiadoDate) : 'A combinar'}\n\n*Chave Pix (CNPJ):*\n${D.cfg.pix}\nFavorecida: ${D.cfg.pixName}\n\nObrigado pela preferência! 🙏`;
  window.open(`https://wa.me/55${phone}?text=${encodeURIComponent(msg)}`, '_blank');
  toast('WhatsApp aberto! 📲', 'ok');
}

// ===================== FIADO =====================
function renderFiado() {
  const fiadoOrders = D.orders.filter(o => o.payment === 'fiado' && o.paymentStatus === 'unpaid');
  const total = fiadoOrders.reduce((a, b) => a + b.total, 0);
  const overdueCount = fiadoOrders.filter(o => isOverdue(o)).length;

  document.getElementById('fi-sum').innerHTML = `
    <div class="cfc-c"><div class="cfc-v" style="color:var(--err)">${fmt(total)}</div><div class="cfc-l">TOTAL EM FIADO</div></div>
    <div class="cfc-c"><div class="cfc-v" style="color:var(--err)">${overdueCount}</div><div class="cfc-l">VENCIDOS</div></div>
    <div class="cfc-c"><div class="cfc-v c-war">${fiadoOrders.length}</div><div class="cfc-l">TOTAL PENDENTES</div></div>`;

  const el = document.getElementById('fi-list');
  if (!fiadoOrders.length) {
    el.innerHTML = '<div class="empty"><span class="empty-ico">🎉</span><div class="empty-txt">Nenhum fiado em aberto!</div></div>';
    return;
  }

  const sorted = [...fiadoOrders].sort((a, b) => isOverdue(a) ? -1 : isOverdue(b) ? 1 : 0);
  el.innerHTML = sorted.map(o => {
    const c = D.clients.find(x => x.id === o.clientId);
    const od = isOverdue(o);
    return `<div class="li ${od ? 'fi-od' : 'fi-ok'}">
      <div>
        <div class="fw7 tc">${c ? c.name : '?'} <span class="ts tl">#${o.num}</span></div>
        <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--copper)">${fmt(o.total)}</div>
        <div class="ts tl mt2">${fmtDate(o.date)} · ${daysLabel(o)}</div>
        <div class="ts tl">📱 ${c ? (c.phone || '-') : '-'}</div>
        ${od ? '<span class="bdg b-over" style="margin-top:6px;display:inline-flex">VENCIDO</span>' : ''}
      </div>
      <div class="li-acts">
        <button class="btn btn-wa btn-sm" onclick="sendWhatsApp('${o.id}')">📲</button>
        <button class="btn btn-sage btn-sm" onclick="openFiadoPay('${o.id}')">✓ Pago</button>
      </div>
    </div>`;
