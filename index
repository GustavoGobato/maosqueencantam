.cli-logo-dot{width:31px;height:31px;background:linear-gradient(135deg,var(--gold-l),var(--copper));border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:14px}
.cli-nav{display:flex;gap:3px;overflow-x:auto;scrollbar-width:none}
