}

function updateBadges() {
  const pendingCount = D.orders.filter(o => o.status === 'pending').length;
  const pb = document.getElementById('pb');
  pb.style.display = pendingCount > 0 ? 'inline' : 'none';
  pb.textContent = pendingCount;

  const fiadoCount = D.orders.filter(o => o.payment === 'fiado' && o.paymentStatus === 'unpaid').length;
  const fb = document.getElementById('fb');
  fb.style.display = fiadoCount > 0 ? 'inline' : 'none';
  fb.textContent = fiadoCount;
}

// ===================== DASHBOARD =====================
function renderDash() {
  const isAdmin = SESSION && SESSION.type === 'admin';

  // Store toggle
  if (isAdmin) {
    const open = D.cfg.storeOpen !== false;
    document.getElementById('store-tgl-w').innerHTML = `
      <div class="store-tgl ${open ? 'open' : 'closed'}" onclick="toggleStore()">
        <div class="tgl-dot ${open ? 'open' : 'closed'}"></div>
        <div>
          <div class="tgl-txt" style="color:${open ? 'var(--sage)' : 'var(--err)'}">${open ? '🟢 Loja Aberta' : '🔴 Loja Fechada'}</div>
          <div class="tgl-sub">${open ? 'Clique para fechar temporariamente' : 'Clique para reabrir'}</div>
        </div>
      </div>`;
  } else {
    document.getElementById('store-tgl-w').innerHTML = '';
  }

  // Goal
  const goal = D.cfg.goal || 500;
  const now = new Date();
  const mStart = new Date(now.getFullYear(), now.getMonth(), 1);
  const monthRev = D.orders
    .filter(o => new Date(o.date) >= mStart && o.paymentStatus === 'paid')
    .reduce((a, b) => a + b.total, 0);
  const pct = Math.min(100, Math.round(monthRev / goal * 100));
  document.getElementById('goal-w').innerHTML = `
    <div class="flex jb ic m2">
      <div class="fw7 tm">🎯 Meta do Mês — ${fmt(monthRev)} <span class="tl">/ ${fmt(goal)}</span></div>
      <div class="ts tl fw7">${pct}%</div>
    </div>
    <div class="pb-w"><div class="pb" style="width:${pct}%"></div></div>`;

  // Stats
  const paid = D.orders.filter(o => o.paymentStatus === 'paid').reduce((a, b) => a + b.total, 0);
  const pending = D.orders.filter(o => o.status === 'pending').length;
  const todayStr = new Date().toDateString();
  const todayRev = D.orders
    .filter(o => new Date(o.date).toDateString() === todayStr && o.paymentStatus === 'paid')
    .reduce((a, b) => a + b.total, 0);
  const fiadoTotal = D.orders.filter(o => o.payment === 'fiado' && o.paymentStatus === 'unpaid').reduce((a, b) => a + b.total, 0);
  const cashPending = D.orders.filter(o => o.payment === 'dinheiro' && o.paymentStatus === 'unpaid').reduce((a, b) => a + b.total, 0);
  const ratedOrders = D.orders.filter(o => o.rating);
  const avgRating = ratedOrders.length ? ratedOrders.reduce((a, b) => a + b.rating, 0) / ratedOrders.length : 0;

  document.getElementById('stats-g').innerHTML = `
    <div class="sc"><span class="sc-ico">💰</span><div class="sc-v">${fmt(paid)}</div><div class="sc-l">Receita Recebida</div></div>
    <div class="sc"><span class="sc-ico">📅</span><div class="sc-v">${fmt(todayRev)}</div><div class="sc-l">Receita Hoje</div></div>
    <div class="sc"><span class="sc-ico">📦</span><div class="sc-v">${pending}</div><div class="sc-l">Pedidos Pendentes</div></div>
    <div class="sc"><span class="sc-ico">📒</span><div class="sc-v">${fmt(fiadoTotal)}</div><div class="sc-l">Fiado em Aberto</div></div>
    <div class="sc"><span class="sc-ico">💵</span><div class="sc-v">${fmt(cashPending)}</div><div class="sc-l">Dinheiro a Receber</div></div>
    <div class="sc"><span class="sc-ico">👥</span><div class="sc-v">${D.clients.filter(c => c.active !== false).length}</div><div class="sc-l">Clientes Ativos</div></div>
    <div class="sc"><span class="sc-ico">⭐</span><div class="sc-v">${avgRating ? avgRating.toFixed(1) : '-'}</div><div class="sc-l">Avaliação Média</div></div>
    <div class="sc"><span class="sc-ico">🛍️</span><div class="sc-v">${D.orders.length}</div><div class="sc-l">Total de Pedidos</div></div>`;

  // Recent orders
  const recent = [...D.orders].sort((a, b) => new Date(b.date) - new Date(a.date)).slice(0, 6);
  const tbody = document.getElementById('dash-t');
  if (!recent.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:32px;color:var(--t4)">Nenhum pedido ainda 🍬</td></tr>';
    return;
  }
  tbody.innerHTML = recent.map(o => {
    const c = D.clients.find(x => x.id === o.clientId);
    return `<tr>
      <td><strong>#${o.num}</strong></td>
      <td>${c ? c.name : '-'}</td>
      <td><strong style="font-family:'Playfair Display',serif;color:var(--copper)">${fmt(o.total)}</strong></td>
      <td>${payBadge(o.payment)}</td>
      <td>${statusBadge(o.status)}</td>
    </tr>`;
  }).join('');
}

function toggleStore() {
  D.cfg.storeOpen = D.cfg.storeOpen === false ? true : false;
  save();
  renderDash();
  updateStoreBanner();
  toast(D.cfg.storeOpen ? '🟢 Loja aberta!' : '🔴 Loja fechada.', D.cfg.storeOpen ? 'ok' : 'warn');
}

// ===================== ORDERS =====================
function renderOrders(filter) {
  ORD_FILTER = filter;
  let orders = [...D.orders].sort((a, b) => new Date(b.date) - new Date(a.date));
  if (filter !== 'all') orders = orders.filter(o => o.status === filter);

  const tbody = document.getElementById('ords-t');
  if (!orders.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:28px;color:var(--t4)">Nenhum pedido</td></tr>';
    return;
  }
  tbody.innerHTML = orders.map(o => {
    const c = D.clients.find(x => x.id === o.clientId);
    const itemsStr = (o.items || []).map(i => `${i.qty}× ${i.name}`).join(', ');
    const cashFlag = o.payment === 'dinheiro' && o.paymentStatus === 'unpaid'
      ? '<br><span class="bdg" style="background:#FEF3C7;color:#92400E;font-size:10px">Aguard. dinheiro</span>' : '';
    return `<tr>
      <td><strong>#${o.num}</strong></td>
      <td>${c ? c.name : '-'}</td>
      <td class="tm" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${itemsStr}</td>
      <td><strong style="font-family:'Playfair Display',serif;color:var(--copper)">${fmt(o.total)}</strong></td>
      <td>${payBadge(o.payment)} ${paidBadge(o.paymentStatus)}${cashFlag}</td>
      <td>${statusBadge(o.status)}</td>
      <td class="ts tl">${o.pickupDate ? fmtDate(o.pickupDate) : '-'}</td>
      <td><button class="btn btn-out btn-sm" onclick="openOrderDetail('${o.id}')">Ver</button></td>
    </tr>`;
